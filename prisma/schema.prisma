generator client {
  provider = "prisma-client-js"
  // Prevents full table scans, uses RLS
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgcrypto, vector] // Example extensions for advanced usage
}

// ----------------------------------------------------------------------
// Base schema setup with RLS enforcement placeholder
// Detailed models for Auth, Company, Employee, Payroll etc. will be added later
// ----------------------------------------------------------------------

// Example organization model to bootstrap
model Organization {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String    @db.VarChar(255)
  pan                 String?   @db.VarChar(10)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz()

  @@map("organizations")
}
